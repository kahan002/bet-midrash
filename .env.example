# LLM provider API key (required)
# Currently configured for Anthropic — see backend/services/llm_client.py to switch providers
LLM_API_KEY=your-api-key-here

# Optional: override the default model
# LLM_MODEL=claude-sonnet-4-20250514

# Optional: override temperature (default 0.3 — low for scholarly consistency)
# LLM_TEMPERATURE=0.3
